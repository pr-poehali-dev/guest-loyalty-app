{
  "tests": [
    {
      "name": "Login existing guest",
      "method": "POST",
      "path": "/",
      "body": {"phone": "+79001234567", "action": "login"},
      "expectedStatus": 200,
      "expectedBody": {"token": "string"},
      "bodyMatcher": "ignore"
    },
    {
      "name": "Login new guest (auto-register)",
      "method": "POST",
      "path": "/",
      "body": {"phone": "+79990000099", "action": "login"},
      "expectedStatus": 200,
      "expectedBody": {"token": "string"},
      "bodyMatcher": "ignore"
    },
    {
      "name": "Login without phone",
      "method": "POST",
      "path": "/",
      "body": {"action": "login"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "ignore"
    }
  ]
}